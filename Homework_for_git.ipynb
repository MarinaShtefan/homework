    "text = 'телефон'\n",
    "len(text)%2\n",
    "part=len(text)//2\n",
    "first_part=text[0:part]\n",
    "second_part=text[part:]\n",
    "first_part_neh=text[0::2]\n",
    "second_part_neh=text[1::2]\n",
    "if len(text)%2==0:\n",
    "    print(second_part+first_part)\n",
    "else:\n",
    "    print(first_part_neh+second_part_neh)"
   ]
